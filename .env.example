APP_NAME=Client Contact Validation API
APP_ENV=development
APP_DEBUG=true
PLATFORM_ADMIN_API_KEY=change-me-management-key
SECRET_ENCRYPTION_KEY=change-me-encryption-key

OPENAI_API_KEY=
OPENAI_SUPPLIER_DISCOVERY_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=cedar
OPENAI_REALTIME_OUTPUT_SPEED=0.93
OPENAI_REALTIME_TEMPERATURE=0.8
OPENAI_REALTIME_MAX_RESPONSE_OUTPUT_TOKENS=180
OPENAI_REALTIME_STYLE_INSTRUCTIONS=Fale como uma atendente brasileira real, profissional e acolhedora. Use frases curtas, diccao clara, ritmo calmo e natural de telefonia e leve sorriso na voz. Faca apenas uma pergunta por vez. Evite soar robotica, teatral ou acelerada demais. Evite listas, markdown, emojis e pontuacao complexa.
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_TRANSCRIPTION_PROMPT=Portugues do Brasil em chamada telefonica de validacao cadastral entre empresas. Podem aparecer nomes de empresas, razao social, nome fantasia, CNPJ e telefones brasileiros. Priorize transcricoes curtas e literais, especialmente: sim, nao, e da empresa, nao e da empresa, numero errado, continua sendo. Preserve pontuacao simples e fillers curtos quando ajudarem a distinguir certeza de hesitacao.
OPENAI_REALTIME_NOISE_REDUCTION=near_field
OPENAI_REALTIME_VAD_THRESHOLD=0.5
OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=300
OPENAI_REALTIME_VAD_SILENCE_DURATION_MS=500
OPENAI_REALTIME_VAD_INTERRUPT_RESPONSE=false
CNPJ_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/contact_validation

META_ACCESS_TOKEN=coloque_o_token_aqui
META_PHONE_NUMBER_ID=coloque_o_phone_number_id_aqui
META_VERIFY_TOKEN='meu_token_local_de_teste'
META_API_VERSION=v22.0

APP_PUBLIC_BASE_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Central de Validacao Cadastral
