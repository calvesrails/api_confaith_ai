APP_NAME=Client Contact Validation API
APP_ENV=development
APP_DEBUG=true

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_TRANSCRIPTION_PROMPT=Portugues do Brasil em chamada telefonica de validacao cadastral. Priorize respostas curtas e literais, especialmente: sim, nao, e da empresa, nao e da empresa, numero errado, continua sendo.
OPENAI_REALTIME_NOISE_REDUCTION=near_field
OPENAI_REALTIME_VAD_INTERRUPT_RESPONSE=false
CNPJ_BASE_URL=https://brasilapi.com.br/api/cnpj/v1

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

DATABASE_URL=sqlite:///./contact_validation.db

META_ACCESS_TOKEN=coloque_o_token_aqui
META_PHONE_NUMBER_ID=coloque_o_phone_number_id_aqui
META_VERIFY_TOKEN='meu_token_local_de_teste'
META_API_VERSION=v22.0
